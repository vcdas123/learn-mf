{
  "name": "discovery-hub",
  "version": "1.0.0",
  "description": "Discovery Hub - Module Federation Exploration Platform",
  "private": true,
  "scripts": {
    "dev:host": "cd host && npm run dev",
    "build:host": "cd host && npm run build",
    "start:host": "cd host && npm run start",
    "dev:cosmos": "cd remotes/cosmos && npm run dev",
    "build:cosmos": "cd remotes/cosmos && npm run build",
    "start:cosmos": "cd remotes/cosmos && npm run start",
    "dev:atlas": "cd remotes/atlas && npm run dev",
    "build:atlas": "cd remotes/atlas && npm run build",
    "start:atlas": "cd remotes/atlas && npm run start",
    "install:all": "npm install && cd host && npm install && cd ../remotes/cosmos && npm install && cd ../atlas && npm install",
    "install:host": "cd host && npm install",
    "install:cosmos": "cd remotes/cosmos && npm install",
    "install:atlas": "cd remotes/atlas && npm install",
    "build:all": "npm run build:cosmos && npm run build:atlas && npm run build:host",
    "build:remotes": "npm run build:cosmos && npm run build:atlas",
    "clean": "rm -rf host/dist remotes/cosmos/dist remotes/atlas/dist",
    "clean:host": "rm -rf host/dist",
    "clean:cosmos": "rm -rf remotes/cosmos/dist",
    "clean:atlas": "rm -rf remotes/atlas/dist"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
