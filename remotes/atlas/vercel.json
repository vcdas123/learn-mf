{
  "installCommand": "npm install && cd remotes/atlas && npm install",
  "buildCommand": "npm run build:atlas",
  "outputDirectory": "remotes/atlas/dist",
  "framework": null,
  "headers": [
    {
      "source": "/remoteEntry.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
