# ============================================
# Micro-Frontend Environment Configuration Template
# ============================================
# Copy this file to .env and update values as needed
# This file is safe to commit to version control
# ============================================

# --------------------------------------------
# Host Application Configuration
# --------------------------------------------
HOST_PORT=3000
HOST_URL=http://localhost:3000

# --------------------------------------------
# Student Grades Remote Configuration
# --------------------------------------------
REMOTE_STUDENT_GRADES_PORT=3105
REMOTE_STUDENT_GRADES_URL=http://localhost:3105

# --------------------------------------------
# Activity Log Remote Configuration
# --------------------------------------------
REMOTE_ACTIVITY_LOG_PORT=3106
REMOTE_ACTIVITY_LOG_URL=http://localhost:3106

# --------------------------------------------
# Image Analyzer Remote Configuration
# --------------------------------------------
REMOTE_IMAGE_ANALYZER_PORT=3107
REMOTE_IMAGE_ANALYZER_URL=http://localhost:3107

# ============================================
# Production URLs (Update for production deployment)
# ============================================
# Uncomment and update these for production builds:
# REMOTE_STUDENT_GRADES_URL=https://student-grades.example.com
# REMOTE_ACTIVITY_LOG_URL=https://activity-log.example.com
# REMOTE_IMAGE_ANALYZER_URL=https://image-analyzer.example.com
