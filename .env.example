# ============================================
# Discovery Hub - Environment Configuration
# ============================================
# Copy this file to .env and fill in values
# For Vercel: set these in each project's settings

# Host Application
HOST_PORT=3000
HOST_URL=http://localhost:3000

# Cosmos Remote (NASA APOD)
REMOTE_COSMOS_PORT=3105
REMOTE_COSMOS_URL=http://localhost:3105
REACT_APP_NASA_API_KEY=your_nasa_api_key_here

# Atlas Remote (Books + Earthquakes)
REMOTE_ATLAS_PORT=3106
REMOTE_ATLAS_URL=http://localhost:3106

# Vault Remote (Precious Metals - gold-api.com)
REMOTE_VAULT_PORT=3107
REMOTE_VAULT_URL=http://localhost:3107
REACT_APP_GOLDAPI_KEY=your_gold_api_key_here
